# RecGPT SQLite (optional catalog/token DB; path from RECGPT_SQLITE_PATH or default)
priv/recgpt.sqlite3
priv/recgpt.sqlite3-shm
priv/recgpt.sqlite3-wal

# Ad-hoc / temporary SQLite (e.g. mix recgpt.ad_hoc_test, one-off scripts)
recgpt_adhoc_*.sqlite
*.sqlite3-journal

# Generated DBs
data/**/*.db
data/**/*.db-shm
data/**/*.db-wal

# Pipeline artifacts (refetch via mix recgpt.refetch)
data/recgpt_layer_3_weight.pt

# FoundationDB (Windows install / build from source)
foundationdb/
fdb_build/
foundationdb-*.msi
foundationdb7-*/
data/recgpt_ckpt_export/*

# Torchx (no disk cache by default)

# Nsight Systems GPU profiles (mix recgpt.ad_hoc_test --profile)
*.nsys-rep
*.nsys-rep.sqlite

# Pipeline / runtime data (Steam, checkpoints, fixture, exports)
data/

# Embedding sanity-check dumps (mix recgpt.compare_embeddings --dump-row N, scripts/embed_one.py)
item*_elixir.raw
item*_sentence_transformers.npy

# Checkpoints (thirdparty/checkpoints) — binaries not committed; use mix recgpt.fetch_vae_ckpt / fetch_ckpt
thirdparty/checkpoints/vae/*.pt
thirdparty/checkpoints/recgpt/*.pt
thirdparty/checkpoints/recgpt/*.npy
thirdparty/checkpoints/recgpt/manifest.json
