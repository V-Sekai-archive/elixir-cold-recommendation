# RecGPT with GPU (EXLA + CUDA). Source from repo root when paths match; otherwise use: ./scripts/run_with_exla_env.sh mix test
# Devcontainer / Debian with CUDA 12.9 + NVSHMEM (config already uses :cuda client).
export LD_LIBRARY_PATH="/usr/local/cuda-12.9/targets/x86_64-linux/lib:/usr/local/cuda-12.9/lib64:/usr/lib/x86_64-linux-gnu/nvshmem/12:/usr/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH:-}"
export PATH="/usr/local/cuda-12.9/bin:${PATH:-}"
export XLA_TARGET=cuda12
