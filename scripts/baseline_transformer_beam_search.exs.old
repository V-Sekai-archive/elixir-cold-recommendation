#!/usr/bin/env elixir

# Minimal baseline test for recommend latency with proper warmup
# Uses stub state to avoid loading real checkpoint/fixture

Application.ensure_all_started(:nx)
Application.ensure_all_started(:jason)

# Note: Backend set via config/test.exs (now EXLA.Backend)
alias RecGPT.TestSupport.FrozenHelpers
alias RecGPT.LayerFreeze

IO.puts("=== Baseline Latency Test (with Warmup) ===")
IO.puts("Backend: #{inspect(Nx.default_backend())}")
IO.puts("")

# Build minimal stub state (2 items)
IO.puts("Building stub state...")
{setup_time, frozen} = :timer.tc(fn ->
  FrozenHelpers.build_frozen([0])
end)
IO.puts("Setup: #{setup_time / 1000} ms")
IO.puts("")

# WARMUP: Run 3 iterations to JIT compile kernels
IO.puts("Warming up (3 iterations for JIT compilation)...")
for i <- 1..3 do
  {warmup_time, _} = :timer.tc(fn ->
    LayerFreeze.recommend(frozen, [0], 5)
  end)
  IO.puts("  Warmup #{i}: #{warmup_time / 1000} ms")
end
IO.puts("")

# MEASUREMENT: Run 10 iterations and collect stats
IO.puts("Measuring (10 iterations)...")
times = for i <- 1..10 do
  {t, result} = :timer.tc(fn ->
    LayerFreeze.recommend(frozen, [0], 5)
  end)
  IO.puts("  Run #{i}: #{t / 1000} ms")
  t
end

# Calculate statistics
sorted = Enum.sort(times)
p50 = Enum.at(sorted, 4) / 1000  # 5th of 10
p90 = Enum.at(sorted, 8) / 1000  # 9th of 10
min_t = hd(sorted) / 1000
max_t = List.last(sorted) / 1000
avg = Enum.sum(times) / length(times) / 1000

IO.puts("")
IO.puts("=== Results (after warmup) ===")
IO.puts("Min: #{:erlang.float_to_binary(min_t, decimals: 2)} ms")
IO.puts("P50: #{:erlang.float_to_binary(p50, decimals: 2)} ms")
IO.puts("P90: #{:erlang.float_to_binary(p90, decimals: 2)} ms")
IO.puts("Max: #{:erlang.float_to_binary(max_t, decimals: 2)} ms")
IO.puts("Avg: #{:erlang.float_to_binary(avg, decimals: 2)} ms")
IO.puts("")
IO.puts("Target P50: 50 ms")
IO.puts("Status: #{if p50 > 50, do: "NEEDS OPTIMIZATION", else: "ON TARGET"}")
